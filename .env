# APIDash MCP Server — Auth Configuration

# Mode 1 — Open (default, no auth)
# Leave both vars unset

# Mode 2 — OAuth 2.1 PKCE (dynamic token generation)
APIDASH_MCP_AUTH=true

# Mode 3 — Static Bearer token
# APIDASH_MCP_TOKEN=your-secret-token-here

# Optional: override base URL for public deployments
# BASE_URL=https://your-domain.com

# Optional: override port (default 8000)
# PORT=8000
