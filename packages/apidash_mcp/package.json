{
  "name": "apidash-mcp",
  "version": "1.0.0",
  "type": "module",
  "description": "APIDash MCP Server - API client capabilities exposed via Model Context Protocol with SEP-1865 UI support",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node dist/index.js",
    "inspector": "npx @modelcontextprotocol/inspector -- tsx src/index.ts",
    "inspector:http": "npx @modelcontextprotocol/inspector http://localhost:3001/mcp"
  },
  "keywords": [
    "mcp",
    "apidash",
    "api-client",
    "model-context-protocol",
    "ui",
    "http",
    "graphql",
    "rest"
  ],
  "license": "MIT",
  "dependencies": {
    "@apidash/mcp-core": "file:../apidash_mcp_core",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.7.9",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "graphql": "^16.10.0",
    "graphql-request": "^7.1.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
