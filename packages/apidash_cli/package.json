{
  "name": "apidash-cli",
  "version": "2.0.0",
  "type": "module",
  "description": "APIDash CLI — Headless terminal executor for APIDash workspace. HTTP, GraphQL, and AI requests — saved & ad-hoc.",
  "main": "dist/index.js",
  "bin": {
    "apidash-cli": "dist/index.js"
  },
  "scripts": {
    "dev":       "tsx src/index.ts",
    "build":     "tsc",
    "build:watch": "tsc --watch",
    "start":     "node dist/index.js",
    "list":      "tsx src/index.ts list",
    "run-req":   "tsx src/index.ts run",
    "request":   "tsx src/index.ts request",
    "graphql":   "tsx src/index.ts graphql",
    "ai":        "tsx src/index.ts ai",
    "save":      "tsx src/index.ts save",
    "providers": "tsx src/index.ts providers"
  },
  "keywords": [
    "apidash",
    "cli",
    "api-client",
    "headless",
    "http",
    "rest",
    "codegen"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.9",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "@apidash/mcp-core": "file:../apidash_mcp_core"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
